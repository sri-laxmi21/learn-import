# Database connection settings
# Format: TENANT_NAME_DB_URL=postgresql://user:password@host:port/database

# Example tenant database URLs
ACME_CORP_DB_URL=postgresql://user:password@localhost:5432/acme_corp_db
TECHNOVA_DB_URL=postgresql://user:password@localhost:5432/technova_db

# Shared database for job tracking (optional but recommended)
# If not set, job tracking will be disabled
SHARED_DB_URL=postgresql://user:password@localhost:5432/ziora_shared_db

# Logging configuration
LOG_LEVEL=INFO
LOG_DIR=logs
# LOG_FILE_FORMAT: Custom log file format (optional)
# If not set, defaults to: {object_type}_YYYYMMDD.log
# Example: LOG_FILE_FORMAT=imports_%Y%m%d_%H%M%S.log

# Import settings
BATCH_SIZE=1000
MAX_ERRORS=100

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8080

